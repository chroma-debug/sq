<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textSize="24sp"
                android:textColor="@color/white"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_title"
                style="@style/TextAppearance.Warden.Title"
                android:textSize="24sp" />
        </LinearLayout>

        <!-- White divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/white" />

        <!-- Permissions Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PERMISSIONS"
            android:textSize="11sp"
            android:textColor="@color/gray_light"
            android:textAllCaps="true"
            android:letterSpacing="0.2"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <!-- Overlay permission -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OVERLAY"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:textAllCaps="true"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvOverlayStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textAllCaps="true" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGrantOverlay"
                style="@style/Widget.Warden.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GRANT"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Accessibility permission -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCESSIBILITY"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:textAllCaps="true"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAccessibilityStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textAllCaps="true" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGrantAccessibility"
                style="@style/Widget.Warden.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GRANT"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Usage Stats permission -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USAGE STATS"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:textAllCaps="true"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REQUIRED FOR APP MONITORING"
                    android:textSize="10sp"
                    android:textColor="@color/gray_light"
                    android:textAllCaps="true" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGrantUsageStats"
                style="@style/Widget.Warden.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GRANT"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gray_mid"
            android:layout_marginTop="16dp" />

        <!-- API Keys Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI API KEYS (ENCRYPTED)"
            android:textSize="11sp"
            android:textColor="@color/gray_light"
            android:textAllCaps="true"
            android:letterSpacing="0.2"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="USED FOR PROOF-OF-WORK PHOTO ANALYSIS. STORED ENCRYPTED ON DEVICE."
            android:textSize="10sp"
            android:textColor="@color/gray_light"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp" />

        <!-- API Key input -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Warden.EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:hint="@string/api_key_label">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etApiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="@color/white"
                android:fontFamily="monospace" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- API Base URL input -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Warden.EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:hint="@string/api_base_url_label">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etApiBaseUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:textColor="@color/white"
                android:fontFamily="monospace" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveKeys"
            style="@style/Widget.Warden.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="32dp"
            android:text="@string/save_keys" />

    </LinearLayout>
</ScrollView>
